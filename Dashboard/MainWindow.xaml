<Window
    x:Class="CrystalFrame.Dashboard.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CrystalFrame.Dashboard"
    Title="CrystalFrame Settings">

    <Grid Padding="12" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="CrystalFrame"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

        <!-- Core Engine Section -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8"
                Padding="10"
                Margin="0,0,0,6">
            <StackPanel Spacing="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Ellipse Grid.Column="0"
                             x:Name="CoreStatusDot"
                             Width="10" Height="10"
                             VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="Core Engine"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="CoreStatusDetail"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <ToggleSwitch Grid.Column="3"
                                  x:Name="CoreRunningToggle"
                                  OnContent="ON"
                                  OffContent="OFF"
                                  Toggled="CoreRunning_Toggled"
                                  Margin="0,-4,0,0"/>
                </Grid>
                <TextBlock Text="Core overlay stays active when Dashboard is closed"
                           FontSize="10"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- System Section (Run at startup) -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Run at Windows startup"
                               FontSize="13"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Launch CrystalFrame automatically when Windows starts"
                               FontSize="10"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
                <ToggleSwitch Grid.Column="1"
                              x:Name="RunAtStartupToggle"
                              OnContent="ON"
                              OffContent="OFF"
                              Toggled="RunAtStartup_Toggled"
                              Margin="0,-4,0,0"/>
            </Grid>
        </Border>

        <!-- TabView for Taskbar and Start Menu -->
        <TabView Grid.Row="4" x:Name="MainTabView"
                 TabWidthMode="Equal"
                 CanDragTabs="False"
                 CanReorderTabs="False"
                 IsAddTabButtonVisible="False">

            <!-- Taskbar Tab -->
            <TabViewItem Header="Taskbar" IsClosable="False">
                <ScrollViewer>
                    <StackPanel Padding="12" Spacing="8">
                        <!-- Enable Toggle -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Taskbar Overlay"
                                       FontSize="14" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <ToggleSwitch Grid.Column="1"
                                          x:Name="TaskbarEnabledToggle"
                                          OnContent="Enabled" OffContent="Disabled"
                                          Toggled="TaskbarEnabled_Toggled"
                                          Margin="0,-4,0,0"/>
                        </Grid>

                        <TextBlock x:Name="TaskbarStatusText" FontSize="11"/>

                        <!-- Opacity -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Transparency" FontSize="13" FontWeight="SemiBold"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="%" VerticalAlignment="Center" FontSize="11"/>
                                <Slider Grid.Column="1" x:Name="TaskbarOpacitySlider" Minimum="0" Maximum="100" StepFrequency="1" ValueChanged="TaskbarOpacity_ValueChanged"/>
                                <TextBlock Grid.Column="2" x:Name="TaskbarOpacityValue" TextAlignment="Right" VerticalAlignment="Center" FontSize="11"/>
                            </Grid>
                        </StackPanel>

                        <!-- Background Color -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Background Color" FontSize="13" FontWeight="SemiBold"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="R" VerticalAlignment="Center" FontSize="11" Foreground="#FF6060"/>
                                <Slider Grid.Column="1" x:Name="TaskbarColorRSlider" Minimum="0" Maximum="255" StepFrequency="1" ValueChanged="TaskbarColorR_ValueChanged"/>
                                <TextBlock Grid.Column="2" x:Name="TaskbarColorRValue" TextAlignment="Right" VerticalAlignment="Center" FontSize="11"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="G" VerticalAlignment="Center" FontSize="11" Foreground="#60C060"/>
                                <Slider Grid.Column="1" x:Name="TaskbarColorGSlider" Minimum="0" Maximum="255" StepFrequency="1" ValueChanged="TaskbarColorG_ValueChanged"/>
                                <TextBlock Grid.Column="2" x:Name="TaskbarColorGValue" TextAlignment="Right" VerticalAlignment="Center" FontSize="11"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="B" VerticalAlignment="Center" FontSize="11" Foreground="#6080FF"/>
                                <Slider Grid.Column="1" x:Name="TaskbarColorBSlider" Minimum="0" Maximum="255" StepFrequency="1" ValueChanged="TaskbarColorB_ValueChanged"/>
                                <TextBlock Grid.Column="2" x:Name="TaskbarColorBValue" TextAlignment="Right" VerticalAlignment="Center" FontSize="11"/>
                            </Grid>
                            <Border Height="18" CornerRadius="3" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                                <Border x:Name="TaskbarColorPreview" Background="Black" CornerRadius="3"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <!-- Start Menu Tab -->
            <TabViewItem Header="Start Menu" IsClosable="False">
                <ScrollViewer>
                    <StackPanel Padding="12" Spacing="8">
                        <!-- Enable Toggle -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Start Menu Overlay"
                                       FontSize="14" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <ToggleSwitch Grid.Column="1"
                                          x:Name="StartEnabledToggle"
                                          OnContent="Enabled" OffContent="Disabled"
                                          Toggled="StartEnabled_Toggled"
                                          Margin="0,-4,0,0"/>
                        </Grid>

                        <TextBlock x:Name="StartStatusText" FontSize="11"/>

                        <!-- Opacity -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Transparency" FontSize="13" FontWeight="SemiBold"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="%" VerticalAlignment="Center" FontSize="11"/>
                                <Slider Grid.Column="1" x:Name="StartOpacitySlider" Minimum="0" Maximum="100" StepFrequency="1" ValueChanged="StartOpacity_ValueChanged"/>
                                <TextBlock Grid.Column="2" x:Name="StartOpacityValue" TextAlignment="Right" VerticalAlignment="Center" FontSize="11"/>
                            </Grid>
                        </StackPanel>

                        <!-- Background Color -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Background Color" FontSize="13" FontWeight="SemiBold"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="R" VerticalAlignment="Center" FontSize="11" Foreground="#FF6060"/>
                                <Slider Grid.Column="1" x:Name="StartBgColorRSlider" Minimum="0" Maximum="255" StepFrequency="1" ValueChanged="StartBgColorR_ValueChanged"/>
                                <TextBlock Grid.Column="2" x:Name="StartBgColorRValue" TextAlignment="Right" VerticalAlignment="Center" FontSize="11"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="G" VerticalAlignment="Center" FontSize="11" Foreground="#60C060"/>
                                <Slider Grid.Column="1" x:Name="StartBgColorGSlider" Minimum="0" Maximum="255" StepFrequency="1" ValueChanged="StartBgColorG_ValueChanged"/>
                                <TextBlock Grid.Column="2" x:Name="StartBgColorGValue" TextAlignment="Right" VerticalAlignment="Center" FontSize="11"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="B" VerticalAlignment="Center" FontSize="11" Foreground="#6080FF"/>
                                <Slider Grid.Column="1" x:Name="StartBgColorBSlider" Minimum="0" Maximum="255" StepFrequency="1" ValueChanged="StartBgColorB_ValueChanged"/>
                                <TextBlock Grid.Column="2" x:Name="StartBgColorBValue" TextAlignment="Right" VerticalAlignment="Center" FontSize="11"/>
                            </Grid>
                            <Border Height="18" CornerRadius="3" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                                <Border x:Name="StartBgColorPreview" Background="Black" CornerRadius="3"/>
                            </Border>
                        </StackPanel>

                        <!-- Text Color -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Text Color" FontSize="13" FontWeight="SemiBold"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="R" VerticalAlignment="Center" FontSize="11" Foreground="#FF6060"/>
                                <Slider Grid.Column="1" x:Name="StartTextColorRSlider" Minimum="0" Maximum="255" StepFrequency="1" ValueChanged="StartTextColorR_ValueChanged"/>
                                <TextBlock Grid.Column="2" x:Name="StartTextColorRValue" TextAlignment="Right" VerticalAlignment="Center" FontSize="11"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="G" VerticalAlignment="Center" FontSize="11" Foreground="#60C060"/>
                                <Slider Grid.Column="1" x:Name="StartTextColorGSlider" Minimum="0" Maximum="255" StepFrequency="1" ValueChanged="StartTextColorG_ValueChanged"/>
                                <TextBlock Grid.Column="2" x:Name="StartTextColorGValue" TextAlignment="Right" VerticalAlignment="Center" FontSize="11"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="B" VerticalAlignment="Center" FontSize="11" Foreground="#6080FF"/>
                                <Slider Grid.Column="1" x:Name="StartTextColorBSlider" Minimum="0" Maximum="255" StepFrequency="1" ValueChanged="StartTextColorB_ValueChanged"/>
                                <TextBlock Grid.Column="2" x:Name="StartTextColorBValue" TextAlignment="Right" VerticalAlignment="Center" FontSize="11"/>
                            </Grid>
                            <Border Height="18" CornerRadius="3" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                                <Border x:Name="StartTextColorPreview" Background="White" CornerRadius="3"/>
                            </Border>
                        </StackPanel>

                        <!-- Menu Items — 2-column layout -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Menu Items" FontSize="13" FontWeight="SemiBold"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <CheckBox Grid.Row="0" Grid.Column="0" x:Name="StartShowControlPanel"
                                          Content="Control Panel" IsChecked="True"
                                          Checked="StartMenuItem_Changed" Unchecked="StartMenuItem_Changed"
                                          FontSize="12"/>
                                <CheckBox Grid.Row="0" Grid.Column="1" x:Name="StartShowDeviceManager"
                                          Content="Device Manager" IsChecked="True"
                                          Checked="StartMenuItem_Changed" Unchecked="StartMenuItem_Changed"
                                          FontSize="12"/>
                                <CheckBox Grid.Row="1" Grid.Column="0" x:Name="StartShowInstalledApps"
                                          Content="Installed Apps" IsChecked="True"
                                          Checked="StartMenuItem_Changed" Unchecked="StartMenuItem_Changed"
                                          FontSize="12"/>
                                <CheckBox Grid.Row="1" Grid.Column="1" x:Name="StartShowDocuments"
                                          Content="Documents" IsChecked="True"
                                          Checked="StartMenuItem_Changed" Unchecked="StartMenuItem_Changed"
                                          FontSize="12"/>
                                <CheckBox Grid.Row="2" Grid.Column="0" x:Name="StartShowPictures"
                                          Content="Pictures" IsChecked="True"
                                          Checked="StartMenuItem_Changed" Unchecked="StartMenuItem_Changed"
                                          FontSize="12"/>
                                <CheckBox Grid.Row="2" Grid.Column="1" x:Name="StartShowVideos"
                                          Content="Videos" IsChecked="True"
                                          Checked="StartMenuItem_Changed" Unchecked="StartMenuItem_Changed"
                                          FontSize="12"/>
                                <CheckBox Grid.Row="3" Grid.Column="0" x:Name="StartShowRecentFiles"
                                          Content="Recent Files" IsChecked="True"
                                          Checked="StartMenuItem_Changed" Unchecked="StartMenuItem_Changed"
                                          FontSize="12"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>
        </TabView>

        <!-- Status Footer -->
        <StackPanel Grid.Row="5">
            <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="0,6,0,0">
                <StackPanel Spacing="2">
                    <TextBlock x:Name="ConnectionStatusText"
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="DebugStatusText"
                               FontSize="10"
                               Foreground="Orange"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
